% Definindo os fatos básicos de parentesco
pai(jose, maria).
pai(jose, joao).
pai(carlos, jose).
mae(ana, maria).
mae(ana, joao).
mae(maria, pedro).

% Regra para verificar se duas pessoas são irmãs
irmao(X, Y) :- 
    pai(P, X), pai(P, Y), 
    mae(M, X), mae(M, Y), 
    X \= Y.

% Regra para verificar se uma pessoa é avô de outra
avo(X, Y) :- 
    pai(X, Z), pai(Z, Y).

avo(X, Y) :- 
    mae(X, Z), mae(Z, Y).