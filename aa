% Fatos de parentesco
pai(jose, maria).
pai(jose, joao).
pai(carlos, jose).
mae(ana, maria).
mae(ana, joao).
mae(maria, pedro).

% Regras para relações familiares
irmao(X, Y) :- 
    pai(P, X), pai(P, Y), 
    mae(M, X), mae(M, Y), 
    X \= Y.

% Corrigindo a regra de avô
avo(X, Y) :- 
    pai(X, Z), (pai(Z, Y) ; mae(Z, Y)).

avo(X, Y) :- 
    mae(X, Z), (pai(Z, Y) ; mae(Z, Y)).