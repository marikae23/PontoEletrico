    -- Função para calcular o fatorial
fatorial :: Integer -> Integer
fatorial 0 = 1
fatorial n = n * fatorial (n - 1)

-- Função para somar os elementos de uma lista
somaLista :: [Int] -> Int
somaLista [] = 0 
somaLista (x:xs) = x + somaLista xs

-- Ponto de entrada do programa
main :: IO ()
main = do
    -- Testando as funções
    print (fatorial 0)         
